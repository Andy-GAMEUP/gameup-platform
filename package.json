{
  "name": "gameup-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev --filter=@gameup/web --filter=@gameup/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "migrate": "npx tsx scripts/migrate-mysql-to-mongodb.ts",
    "restart": "bash scripts/restart-all.sh",
    "start:all": "bash scripts/restart-all.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "mongoose": "^8.23.0",
    "mysql2": "^3.19.1",
    "turbo": "^2.8.13",
    "typescript": "^5.7.3"
  }
}
